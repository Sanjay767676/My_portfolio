{
  "github": {
    "silent": true
  },
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/skills",
      "destination": "/api/skills"
    },
    {
      "source": "/api/projects",
      "destination": "/api/projects"
    },
    {
      "source": "/api/contact",
      "destination": "/api/contact"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "outputDirectory": "dist"
}
